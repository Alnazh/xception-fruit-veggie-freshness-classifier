# Dataset asli (terlalu besar untuk GitHub, unduh manual dari Kaggle)
dataset/
data/

# Folder cache tambahan yang mungkin dibuat saat eksperimen lokal
feature_cache/

# Folder reports lama di root (sudah dipindah ke static/reports/)
reports/

# Model penuh hasil training: besar (100MB+), TIDAK di-commit ke Git karena kena limit
# GitHub. Dipakai untuk development lokal saja, hasil dari `python train_model.py`.
model/*.keras
model/*.h5

# Bobot ringkas (float16, terkompresi) & metadata kecil TETAP di-commit supaya deploy
# (misalnya ke Railway) tetap punya model tanpa perlu file besar di atas.
!model/xception_fruit_freshness_fp16.npz
!model/class_indices.json
!model/training_metrics.json

# Hasil upload pengguna & laporan training
static/uploads/*
!static/uploads/.gitkeep
static/reports/*
!static/reports/.gitkeep

# Dataset hasil split otomatis
dataset_split/

# Python
__pycache__/
*.pyc
venv/
.venv/

# OS/editor
.DS_Store
.vscode/

# File arsip sementara, tidak perlu ikut di-commit
*.zip
.ipynb_checkpoints/
